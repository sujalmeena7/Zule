{
  "name": "zule",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest --run",
    "fetch:models": "node scripts/fetch-models.mjs",
    "test:e2e": "playwright test",
    "test:coverage": "vitest --run --coverage",
    "ci": "npm run lint && npm run build && npm run test:coverage && npm run test:e2e",
    "electron:dev": "vite --config vite.electron.config.ts",
    "electron:build": "vite build --config vite.electron.config.ts && electron-builder --win",
    "electron:preview": "vite build --config vite.electron.config.ts && electron ."
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.49.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "3.2.4",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "6.0.0",
    "fast-check": "3.23.2",
    "globals": "^17.6.0",
    "jsdom": "25.0.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-electron": "^1.0.4",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vitest": "3.2.4"
  }
}
